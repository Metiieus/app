{
  "name": "tikfactory-backend",
  "version": "2.0.0",
  "description": "TikFactory — Máquina de vídeos automática para TikTok",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate:mysql",
    "db:push": "drizzle-kit push:mysql",
    "db:migrate": "drizzle-kit push:mysql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@trpc/server": "^11.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.30.10",
    "express": "^4.22.1",
    "mysql2": "^3.18.0",
    "node-cron": "^3.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.33",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.3.0"
  }
}

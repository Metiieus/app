# ============================================================
# TikFactory — Máquina de Vídeos TikTok
# ============================================================

# Configurações do Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados (MySQL / TiDB)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=tikfactory

# ============================================================
# APIs de Inteligência Artificial (OBRIGATÓRIO)
# ============================================================

# Gemini AI — Geração de roteiros virais
# Obter em: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# OpenAI DALL-E — Geração de imagens (opcional)
# Obter em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_openai_aqui

# ElevenLabs — Narração ultra-realista (opcional)
# Obter em: https://elevenlabs.io
ELEVENLABS_API_KEY=sua_chave_elevenlabs_aqui

# ============================================================
# TikTok API (para publicação automática)
# Obter em: https://developers.tiktok.com
# ============================================================

TIKTOK_CLIENT_KEY=sua_client_key_tiktok_aqui
TIKTOK_CLIENT_SECRET=seu_client_secret_tiktok_aqui
TIKTOK_ACCESS_TOKEN=seu_access_token_tiktok_aqui
TIKTOK_REDIRECT_URI=http://localhost:3001/auth/tiktok/callback
